# Template file for 'signalhound-spike'
pkgname=signalhound-spike
version=4.0.12
revision=1
archs="x86_64"
build_style=fetch
hostmakedepends="unzip"
depends="libglvnd libusb"
short_desc="Spectrum analyzer software for Signal Hound test equipment"
maintainer="fklose <felix.f.klose@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://signalhound.com/spike/"
changelog="https://signalhound.com/sigdownloads/Spike/change_log.txt"
# distfiles="https://signalhound.com/sigdownloads/Spike/Spike(RHEL8x64)_4_0_12.zip"
# checksum=2cbe34221d0017f51757522bb5abf64a7e9141184541d9547c889aa164c17d3b
distfiles="https://signalhound.com/sigdownloads/Spike/Spike(Ubuntu22.04x64)_4_0_12.zip"
checksum=89c41014e3eb7557b305d4bc7eef3b0d032036e93c99b76d2b40f8272a94d1b1
nopie=yes

# TODO: Looks like I need to package the matlab runtime otherwise xbps will complain
# TODO: I should probably install the package in /opt?
do_install() {
	# unzip ${wrksrc}/"Spike(RHEL8x64)_4_0_12.zip"
	# spike_path=${wrksrc}/"Spike(RHEL8x64)_4_0_12"

	unzip ${wrksrc}/"Spike(Ubuntu22.04x64)_4_0_12.zip"
	spike_path=${wrksrc}/"Spike(Ubuntu22.04x64)_4_0_12"

	# Install application binaries
	vmkdir /opt/signalhound-spike 755
	vcopy ${spike_path}/* /opt/signalhound-spike

	# Fix permissions for the executable
	# chmod 755 ${PKGDESTDIR}/opt/signalhound-spike/bin/Spike
	chmod -R 755 ${PKGDESTDIR}/opt/signalhound-spike

	# Place symlink in /usr/bin
	vmkdir /usr/bin
	ln -s /opt/signalhound-spike/bin/Spike ${PKGDESTDIR}/usr/bin

	# Clean up the folder we just put in /usr/lib
	rm -r ${PKGDESTDIR}/opt/signalhound-spike/assets # This contains desktop icons
	rm ${PKGDESTDIR}/opt/signalhound-spike/sh.rules # These are the udev rules
	rm ${PKGDESTDIR}/opt/signalhound-spike/com.signalhound.spike.desktop # This is the .desktop file
	rm ${PKGDESTDIR}/opt/signalhound-spike/setup.sh # This is the setup script
	rm ${PKGDESTDIR}/opt/signalhound-spike/Spike # From what I can gather this just runs the program in ./bin

	# Install udev rules
	vmkdir /usr/lib/udev/rules.d
	vinstall ${spike_path}/sh.rules 744 /usr/lib/udev/rules.d/99-signalhound-spike.rules

	# Install the desktop icon
	vmkdir /usr/share/icons/hicolor/256x256/apps
	vinstall ${spike_path}/assets/com.signalhound.spike.png 744 /usr/share/icons/hicolor/256x256/apps/signalhound-spike.png

	# Install the .desktop file
	vmkdir /usr/share/applications
	vinstall ${FILESDIR}/signalhound-spike.desktop 744 /usr/share/applications
}
